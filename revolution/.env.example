# Server/pipeline secrets are never shipped to the client. The one VITE_ value
# below is a public Turnstile widget id, not a secret.
# Local tools read revolution/.env or the parent workspace .env; production
# values belong in the hosting provider's encrypted environment settings.

# Reactor (world model sessions; used by the dev token broker at /api/session)
REACTOR_API_KEY=

# Production session admission (the Vite dev broker does not use these).
# Public widget id embedded in the browser bundle:
VITE_TURNSTILE_SITE_KEY=
# Server-only Turnstile validation and exact comma-separated production hosts:
TURNSTILE_SECRET_KEY=
TURNSTILE_EXPECTED_HOSTNAMES=
# Server-only durable, atomic replay/rate/global-budget store:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Random server-only value, at least 32 characters, used to HMAC client ids:
SESSION_CLIENT_HASH_SECRET=
# No code defaults: production fails closed unless all three are explicit.
SESSION_CLIENT_LIMIT=
SESSION_CLIENT_WINDOW_SECONDS=
SESSION_GLOBAL_DAILY_LIMIT=

# World Labs Marble (pipeline: splat world generation)
WORLDLABS_API_KEY=

# ElevenLabs (pipeline: narration VO + SFX)
# Library (non-premade) voices need a paid plan; the API returns 402 on free.
ELEVENLABS_API_KEY=
# Voice id for the narrator (pick one in the ElevenLabs voice library)
ELEVENLABS_NARRATOR_VOICE_ID=
# Diegetic cast — one voice per speaker in docs/narration-scripts.md.
# Each is optional: an unset voice skips just that speaker's lines.
ELEVENLABS_MARINER_VOICE_ID=
ELEVENLABS_BOSUN_VOICE_ID=
ELEVENLABS_SERGEANT_VOICE_ID=

# Tripo (pipeline: 3D prop generation)
TRIPO_API_KEY=

# fal.ai (pipeline: GPT Image 2 starting frames for Reactor + Marble)
FAL_KEY=
