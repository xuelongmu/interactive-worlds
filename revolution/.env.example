# Server/pipeline keys only — never shipped to the client.
# The app reads these from revolution/.env or the parent workspace .env.

# Reactor (world model sessions; used by the dev token broker at /api/session)
REACTOR_API_KEY=

# World Labs Marble (pipeline: splat world generation)
WORLDLABS_API_KEY=

# ElevenLabs (pipeline: narration VO + SFX)
ELEVENLABS_API_KEY=
# Voice id for the narrator (pick one in the ElevenLabs voice library)
ELEVENLABS_NARRATOR_VOICE_ID=

# Tripo (pipeline: 3D prop generation)
TRIPO_API_KEY=

# fal.ai (pipeline: GPT Image 2 starting frames for Reactor + Marble)
FAL_KEY=
