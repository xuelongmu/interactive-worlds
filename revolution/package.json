  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "node --test --experimental-strip-types src/*.test.mjs src/engine/*.test.mjs && vitest run src/engine/audio.test.ts src/engine/cues.test.ts src/engine/director.test.ts src/renderers/worldmodel.test.ts src/scenes/diegetic-vo.test.ts",
