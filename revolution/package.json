    "pipeline:models": "node pipeline/models.mjs"
  },
  "dependencies": {
    "@reactor-models/lingbot-world-2": "^0.3.3",
    "@reactor-team/js-sdk": "^2.12.1",
    "@sparkjsdev/spark": "^2.1.0",
    "@upstash/redis": "1.38.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/three": "^0.185.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
